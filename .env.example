# Rosetta configuration. Copy to `.env` and fill in, or export these directly.
#
# Leave DATAHUB_GMS_URL unset to run in DEMO mode (bundled reproducible graph).
# Set it to a reachable DataHub to run in LIVE mode (real reads + write-back).

# DATAHUB_GMS_URL=http://localhost:8080
# DATAHUB_GMS_TOKEN=your-personal-access-token

# Force demo mode even if DATAHUB_GMS_URL is set (useful for the hosted demo):
# ROSETTA_FORCE_DEMO=1
